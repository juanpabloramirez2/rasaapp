# ─────────────────────────────────────────────────────────────────
# Copiar este archivo como .env y completar los valores reales.
# NUNCA subir el archivo .env al repositorio.
# ─────────────────────────────────────────────────────────────────

# Perfil activo de Spring (prod | dev)
SPRING_PROFILES_ACTIVE=prod

# Puerto en el que expone la app en el host
APP_PORT=8080

# ── Base de datos ─────────────────────────────────────────────────
DB_NAME=rasadb
DB_USER=rasauser
DB_PASS=cambia_esta_contraseña
DB_ROOT_PASS=cambia_esta_contraseña_root

# ── Credenciales del administrador del panel ──────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia_esta_contraseña_admin
